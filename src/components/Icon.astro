  book: '<path d="M12 7c-1.6-1.6-4.2-2.2-8-2.2v13c3.8 0 6.4.6 8 2.2 1.6-1.6 4.2-2.2 8-2.2v-13c-3.8 0-6.4.6-8 2.2Z"/><path d="M12 7v13"/>',
