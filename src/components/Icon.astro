  pan: '<circle cx="10.5" cy="13.5" r="6.5"/><path d="M16.5 9.5l4.5-3"/><path d="M7.8 11c.4-1.4 1.7-2.3 3.2-2.3"/>',
  droplet: '<path d="M12 3C12 3 5.5 9.8 5.5 14.8a6.5 6.5 0 0 0 13 0C18.5 9.8 12 3 12 3Z"/>',
  // utility
  check: '<circle cx="12" cy="12" r="9.2"/><path d="M7.8 12.3l2.7 2.7L16.4 9"/>',
  star: '<path d="M12 3.2l2.6 5.3 5.8.8-4.2 4.1 1 5.8L12 16.5 6.9 19.2l1-5.8L3.7 9.3l5.8-.8Z"/>',
  phone: '<path d="M5 4h3l1.5 4-2 1.5a11 11 0 0 0 5 5l1.5-2 4 1.5V18a2 2 0 0 1-2.2 2A15.5 15.5 0 0 1 3 6.2 2 2 0 0 1 5 4Z"/>',
