  // social proof / trust
  stethoscope: '<path d="M6 3v4.5a4 4 0 0 0 8 0V3"/><path d="M6 3H4.5M14 3h1.5"/><path d="M10 11.5v2a5 5 0 0 0 9 .2"/><circle cx="19" cy="11" r="2"/>',
  users: '<circle cx="9" cy="8" r="3.2"/><path d="M3.5 19a5.5 5.5 0 0 1 11 0"/><path d="M15.5 5.2a3.2 3.2 0 0 1 0 6"/><path d="M16.5 13.4a5.5 5.5 0 0 1 4 5.6"/>',
