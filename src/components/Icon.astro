  kitchen: '<path d="M4 10.5h16v3.5a4.5 4.5 0 0 1-4.5 4.5h-7A4.5 4.5 0 0 1 4 14Z"/><path d="M4 11.2H2.2"/><path d="M20 11.2h1.8"/><path d="M9 7.2c0-1 1-1 1-2M13 7.2c0-1 1-1 1-2"/>',
