---
import Icon from './Icon.astro';
const cols = [
  { title: 'Explore', links: ['Products', 'About Us', 'Shop', 'Replacements'] },
  { title: 'Company', links: ['Our Story', 'Home Assessment', 'Water Testing', 'Privacy Policy'] },
];
const social = ['X', 'Instagram', 'YouTube', 'Vimeo'];
---
<footer class="ft">
  <div class="container ft__inner">
    <div class="ft__brand">
      <img src="/logos/logo-horizontal-white.svg" alt="Healthy Technologies" />
      <p class="ft__tag">We help people live longer, healthier lives.</p>
      <div class="ft__contact">
        <a href="tel:7543363394"><Icon name="phone" size={18} /> 754-336-3394</a>
        <a href="mailto:info@healthytechs.com"><Icon name="mail" size={18} /> info@healthytechs.com</a>
      </div>
      <p class="ft__ship">International shipping available — contact us.</p>
    </div>

    {cols.map((c) => (
      <div class="ft__col">
        <div class="ft__col-title">{c.title}</div>
        <ul>{c.links.map((l) => <li><a href="#">{l}</a></li>)}</ul>
      </div>
    ))}

    <div class="ft__col">
      <div class="ft__col-title">Follow</div>
      <ul>{social.map((s) => <li><a href="#">{s}</a></li>)}</ul>
    </div>
  </div>

  <div class="ft__bar">
    <div class="container ft__bar-inner">
      <span>© 2026 Healthy Technologies LLC</span>
      <span>Your home should heal you, not harm you.</span>
    </div>
  </div>
</footer>

<style>
  .ft{background:var(--blue);color:#fff;}
  .ft__inner{
    display:grid;grid-template-columns:1.7fr 1fr 1fr 1fr;gap:40px;
    padding-top:64px;padding-bottom:48px;
  }
  .ft__brand img{height:40px;margin-bottom:18px;}
  .ft__tag{font-size:17px;color:#fff;max-width:300px;margin-bottom:22px;}
  .ft__contact{display:flex;flex-direction:column;gap:10px;margin-bottom:14px;}
  .ft__contact a{display:inline-flex;align-items:center;gap:10px;color:#D6E3F2;font-weight:500;}
  .ft__contact a:hover{color:#fff;}
  .ft__ship{font-size:14px;color:#9FB8D6;}
  .ft__col-title{font-size:13px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:#9FB8D6;margin-bottom:16px;}
  .ft__col ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:11px;}
  .ft__col a{color:#D6E3F2;font-size:15px;}
  .ft__col a:hover{color:#fff;}
  .ft__bar{border-top:1px solid rgba(255,255,255,.16);}
  .ft__bar-inner{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;padding:22px 48px;font-size:14px;color:#9FB8D6;}
  @media(max-width:900px){
    .ft__inner{grid-template-columns:1fr 1fr;gap:32px;}
    .ft__brand{grid-column:1 / -1;}
  }
  @media(max-width:560px){ .ft__inner{grid-template-columns:1fr;} }
</style>
